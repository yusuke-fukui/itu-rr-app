{
  "_source": "ITU-R Handbook on Small Satellites (2023 edition), Chapter 3",
  "_description": "ITU RR条文間の関係マップ。ツリーエンジンが関連条文を推論する際の知識ベース。",

  "regulatory_flow": {
    "description": "衛星ネットワークの規制手続き全体フロー",
    "phases": [
      {
        "phase": "1_frequency_selection",
        "description": "周波数選定・分配確認",
        "key_articles": ["Art.5", "No.4.4"],
        "details": "Art.5の周波数分配表と脚注を確認。脚注がArt.9の調整要否を決定する。"
      },
      {
        "phase": "2_api_or_cr",
        "description": "事前公表(API)または調整要請(CR)の提出",
        "branches": {
          "not_subject_to_coordination": {
            "description": "調整対象外（Art.9 Section IA）",
            "articles": ["No.9.1", "No.9.2", "No.9.2B"],
            "publications": ["API/A", "API/B"],
            "timeline": "API受領後約6ヶ月〜最大7年でNotification"
          },
          "subject_to_coordination": {
            "description": "調整対象（Art.9 Section II）",
            "articles": ["No.9.1A", "No.9.30"],
            "publications": ["API/C (=CR抜粋)", "CR/C", "CR/D", "CR/E"],
            "timeline": "CR受領後4ヶ月で審査、4ヶ月コメント期間、最大7年でNotification"
          }
        }
      },
      {
        "phase": "3_coordination",
        "description": "調整手続き（調整対象のみ）",
        "key_articles": ["No.9.35", "No.9.36", "No.9.38", "No.9.48", "No.9.52"],
        "details": "BRがArt.9.35に基づき審査、9.36で影響主管庁を特定、CR/Cで公表"
      },
      {
        "phase": "4_notification",
        "description": "通告・記録",
        "key_articles": ["No.11.2", "No.11.9", "No.11.15", "No.11.25", "No.11.28"],
        "publications": ["Part I-S", "Part II-S", "Part III-S"],
        "details": "通告情報を提出→Part I-Sで公表→審査→Part II-S(favorable)またはPart III-S(unfavorable)"
      },
      {
        "phase": "5_examination",
        "description": "BR審査（Art.11.31〜11.33）",
        "key_articles": ["No.11.31", "No.11.32", "No.11.32A", "No.11.33"],
        "details": "11.31: RR適合性、11.32: 調整手続き適合性、11.32A: 有害干渉の可能性"
      },
      {
        "phase": "6_recording",
        "description": "国際周波数登録簿(MIFR)への記録",
        "key_articles": ["No.11.41", "No.8.1", "No.8.3"],
        "details": "Favorable findingで記録。調整未完了でも11.41で記録可能（条件付き）"
      },
      {
        "phase": "7_biu",
        "description": "使用開始(Bringing Into Use)",
        "key_articles": ["No.11.44", "No.11.44B", "No.11.44C", "No.11.44D", "No.11.44E", "No.11.47"],
        "details": "API/CR受領から7年以内。FSS/MSS/BSSは90日間継続運用の確認が必要。"
      }
    ]
  },

